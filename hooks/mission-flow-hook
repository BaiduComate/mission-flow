#!/usr/bin/env sh
set -eu

fail_open() {
  case "${1:-}" in
    session-start)
      printf '{"additionalContext":""}'
      ;;
    pre-tool-use)
      printf '{"decision":"allow"}'
      ;;
    post-tool-use)
      printf '{"continue":true}\n'
      ;;
    version|--version|-v)
      printf 'mission-flow-hook launcher: unsupported platform or missing binary\n'
      ;;
    *)
      printf '{}'
      ;;
  esac
  exit 0
}

script_path="$0"
case "${script_path}" in
  */*) script_dir="${script_path%/*}" ;;
  *) script_dir="." ;;
esac

if ! hooks_dir="$(cd "${script_dir}" 2>/dev/null && pwd -P)"; then
  fail_open "${1:-}"
fi
plugin_dir="$(dirname "${hooks_dir}")"
bin_dir="${plugin_dir}/bin"
bin_base_url="https://vercel-static.bj.bcebos.com/stash/v1/0b72aae/comate-plus-web/7a0aaaf/mission-flow/bin"

plugin_version() {
  sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "${plugin_dir}/plugin.json" 2>/dev/null | sed -n '1p'
}

os="$(uname -s 2>/dev/null || true)"
arch="$(uname -m 2>/dev/null || true)"

case "${os}" in
  Darwin) goos="darwin" ;;
  Linux) goos="linux" ;;
  *) fail_open "${1:-}" ;;
esac

case "${arch}" in
  arm64|aarch64) goarch="arm64" ;;
  x86_64|amd64) goarch="amd64" ;;
  *) fail_open "${1:-}" ;;
esac

filename="mission-flow-hook-${goos}-${goarch}"
target="${bin_dir}/${filename}"
expected_version="$(plugin_version)"
version_file="${target}.version"
download_url="${bin_base_url}/${expected_version}/${filename}"
lock_dir="${target}.lock"

now_seconds() {
  date '+%s' 2>/dev/null || printf '0'
}

lock_is_stale() {
  lock_pid="$(cat "${lock_dir}/pid" 2>/dev/null || true)"
  if [ -n "${lock_pid}" ]; then
    kill -0 "${lock_pid}" 2>/dev/null && return 1
    return 0
  fi

  lock_created="$(cat "${lock_dir}/created_at" 2>/dev/null || true)"
  now="$(now_seconds)"
  case "${lock_created}" in
    ''|*[!0-9]*) return 0 ;;
  esac
  case "${now}" in
    ''|*[!0-9]*|0) return 1 ;;
  esac

  [ $((now - lock_created)) -gt 300 ]
}

acquire_download_lock() {
  if mkdir "${lock_dir}" 2>/dev/null; then
    now_seconds > "${lock_dir}/created_at" 2>/dev/null || true
    return 0
  fi

  if lock_is_stale; then
    rm -rf "${lock_dir}" 2>/dev/null || true
    if mkdir "${lock_dir}" 2>/dev/null; then
      now_seconds > "${lock_dir}/created_at" 2>/dev/null || true
      return 0
    fi
  fi

  return 1
}

download_target() {
  [ -n "${expected_version}" ] || return 1
  mkdir -p "${bin_dir}" 2>/dev/null || return 1
  [ -x "${target}" ] && [ "$(cat "${version_file}" 2>/dev/null || true)" = "${expected_version}" ] && return 0

  tmp="${target}.tmp.$$"
  tmp_version="${version_file}.tmp.$$"
  rm -f "${tmp}" 2>/dev/null || true
  rm -f "${tmp_version}" 2>/dev/null || true

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL --connect-timeout 5 --max-time 120 "${download_url}" -o "${tmp}" || {
      rm -f "${tmp}" 2>/dev/null || true
      rm -f "${tmp_version}" 2>/dev/null || true
      return 1
    }
  elif command -v wget >/dev/null 2>&1; then
    wget -q -T 120 -O "${tmp}" "${download_url}" || {
      rm -f "${tmp}" 2>/dev/null || true
      rm -f "${tmp_version}" 2>/dev/null || true
      return 1
    }
  else
    return 1
  fi

  chmod 755 "${tmp}" 2>/dev/null || {
    rm -f "${tmp}" 2>/dev/null || true
    rm -f "${tmp_version}" 2>/dev/null || true
    return 1
  }
  printf '%s\n' "${expected_version}" > "${tmp_version}" 2>/dev/null || {
    rm -f "${tmp}" 2>/dev/null || true
    rm -f "${tmp_version}" 2>/dev/null || true
    return 1
  }

  mv "${tmp}" "${target}" 2>/dev/null || {
    rm -f "${tmp}" 2>/dev/null || true
    rm -f "${tmp_version}" 2>/dev/null || true
    return 1
  }
  mv "${tmp_version}" "${version_file}" 2>/dev/null || {
    rm -f "${tmp_version}" 2>/dev/null || true
    return 1
  }
}

start_async_download() {
  mkdir -p "${bin_dir}" 2>/dev/null || return 1
  acquire_download_lock || return 1

  (
    trap 'rm -rf "${lock_dir}"' EXIT HUP INT TERM
    download_target || true
  ) </dev/null >/dev/null 2>&1 &

  printf '%s\n' "$!" > "${lock_dir}/pid" 2>/dev/null || true
}

if [ ! -x "${target}" ] || [ "$(cat "${version_file}" 2>/dev/null || true)" != "${expected_version}" ]; then
  start_async_download || true
  fail_open "${1:-}"
fi

exec "${target}" "$@"
