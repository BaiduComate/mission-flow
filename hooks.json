{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.comate/plugins/mission-flow/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^skill$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.comate/plugins/mission-flow/hooks/pre-tool-use.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
