{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.comate/plugins/mission-flow/hooks/mission-flow-hook session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^skill$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.comate/plugins/mission-flow/hooks/mission-flow-hook pre-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.comate/plugins/mission-flow/hooks/mission-flow-hook post-tool-use",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
